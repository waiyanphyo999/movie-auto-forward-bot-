from pyrogram import Client, filters
import google.generativeai as genai
import asyncio

# --- ၁။ Telegram API အချက်အလက်များ ---
# (my.telegram.org သို့သွား၍ API ID နှင့် API Hash ကို ယူပါ)
API_ID = "YOUR_API_ID_HERE"      # ဥပမာ - 1234567 (ဂဏန်းများသာ)
API_HASH = "YOUR_API_HASH_HERE"  # ဥပမာ - "a1b2c3d4e5f6..."

# --- ၂။ AI API အချက်အလက်များ ---
# (Google AI Studio မှ Gemini API Key အခမဲ့ ယူနိုင်ပါသည်)
GEMINI_API_KEY = "YOUR_GEMINI_API_KEY_HERE"
genai.configure(api_key=GEMINI_API_KEY)
model = genai.GenerativeModel('gemini-pro')

# --- ၃။ Channel အချက်အလက်များ ---
# စောင့်ကြည့်မည့် သူများ Channel Username များ
SOURCE_CHANNELS = ["@source_channel_1", "@source_channel_2"] 
# ပြန်တင်မည့် သင့်ကိုယ်ပိုင် Channel Username
DESTINATION_CHANNEL = "@your_myanmar_channel" 

# Userbot ကို စတင်ခြင်း
app = Client("my_account_session", api_id=API_ID, api_hash=API_HASH)

def rewrite_text(original_text):
    """စာသားများကို AI ဖြင့် အဓိပ္ပာယ်မပြောင်းဘဲ ပြန်လည်ရေးသားမည့် Function"""
    try:
        # AI ကို ခိုင်းမည့် စာသား (Prompt) - လိုအပ်သလို ပြင်ဆင်နိုင်သည်
        prompt = f"အောက်ပါစာသားကို မြန်မာလိုပဲ အဓိပ္ပာယ်မပြောင်းဘဲ စာသား/အရေးအသား ပုံစံပြောင်းပြီး ပြန်ရေးပေးပါ။ ကြော်ငြာဆန်ဆန် ဆွဲဆောင်မှုရှိအောင် ရေးပေးပါ။:\n\n{original_text}"
        response = model.generate_content(prompt)
        return response.text
    except Exception as e:
        print(f"AI Error: {e}")
        return original_text # Error ဖြစ်ပါက မူရင်းစာသားကိုသာ ပြန်ပေးမည်

@app.on_message(filters.chat(SOURCE_CHANNELS))
async def forward_and_rewrite(client, message):
    # စာသားသီးသန့် (Text Only) ဖြစ်လျှင်
    if message.text:
        print("စာအသစ် တွေ့ရှိပါသည်... AI ဖြင့် စာသားပြောင်းနေပါသည်...")
        new_text = rewrite_text(message.text)
        await client.send_message(DESTINATION_CHANNEL, new_text)
        print("သင့် Channel သို့ အောင်မြင်စွာ တင်ပြီးပါပြီ။\n---")
        
    # ဓာတ်ပုံ သို့မဟုတ် ဗီဒီယို (Media) နှင့် စာသားတွဲပါလျှင်
    elif message.photo or message.video:
        print("ဓာတ်ပုံ/ဗီဒီယို အသစ်တွေ့ရှိပါသည်...")
        caption = message.caption if message.caption else ""
        new_caption = rewrite_text(caption) if caption else ""
        # မူရင်း ပုံ/ဗီဒီယိုကို ယူပြီး စာသားအသစ်ဖြင့် ပြန်တင်မည်
        await message.copy(DESTINATION_CHANNEL, caption=new_caption)
        print("မီဒီယာနှင့် စာသားအသစ် တင်ပြီးပါပြီ။\n---")

print("Userbot စတင် အလုပ်လုပ်နေပါပြီ...")
app.run()
