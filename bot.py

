from pyrogram import Client, filters
from pyrogram.types import InlineKeyboardMarkup, InlineKeyboardButton
import google.generativeai as genai
import asyncio

# --- ၁။ Telegram API အချက်အလက်များ ---
API_ID = "YOUR_API_ID"              # ဂဏန်းများသာ
API_HASH = "YOUR_API_HASH"          # စာသားများ
SESSION_STRING = "YOUR_STRING_SESSION" # Render တွင် Run ရန် မဖြစ်မနေ လိုအပ်ပါသည်

# --- ၂။ AI API နှင့် Channel အချက်အလက်များ ---
GEMINI_API_KEY = "YOUR_GEMINI_API_KEY"
genai.configure(api_key=GEMINI_API_KEY)
model = genai.GenerativeModel('gemini-pro')

SOURCE_CHANNELS = ["@source_channel_1"] # စောင့်ဖတ်မည့် သူများ Channel
DESTINATION_CHANNEL = "@your_channel"   # ပြန်တင်မည့် သင့် Channel

app = Client("my_bot", session_string=SESSION_STRING, api_id=API_ID, api_hash=API_HASH)

def rewrite_text(original_text):
    try:
        prompt = f"အောက်ပါစာသားကို မြန်မာလိုပဲ အဓိပ္ပာယ်မပြောင်းဘဲ စာသား/အရေးအသား ပုံစံပြောင်းပြီး ပြန်ရေးပေးပါ။ ကြော်ငြာဆန်ဆန် ဆွဲဆောင်မှုရှိအောင် ရေးပေးပါ။:\n\n{original_text}"
        response = model.generate_content(prompt)
        return response.text
    except Exception as e:
        print(f"AI Error: {e}")
        return original_text

@app.on_message(filters.chat(SOURCE_CHANNELS))
async def forward_and_rewrite(client, message):
    # --- ခလုတ် (Inline Buttons) ဖန်တီးခြင်း ---
    reply_markup = InlineKeyboardMarkup([
        [InlineKeyboardButton("📢 Channel သို့ Join ရန်", url="https://t.me/your_channel")],
        [InlineKeyboardButton("💬 Admin သို့ ဆက်သွယ်ရန်", url="https://t.me/your_admin_username")]
    ])

    # စာသားသီးသန့်ဖြစ်လျှင်
    if message.text:
        new_text = rewrite_text(message.text)
        await client.send_message(
            DESTINATION_CHANNEL, 
            new_text, 
            reply_markup=reply_markup # ခလုတ်ထည့်သွင်းခြင်း
        )
        
    # ဓာတ်ပုံ သို့မဟုတ် ဗီဒီယိုဖြစ်လျှင်
    elif message.photo or message.video:
        caption = message.caption if message.caption else ""
        new_caption = rewrite_text(caption) if caption else ""
        
        # မူရင်း Media ကိုယူ၍ စာသားအသစ်၊ ခလုတ်အသစ်ဖြင့် တင်ခြင်း
        await message.copy(
            DESTINATION_CHANNEL, 
            caption=new_caption, 
            reply_markup=reply_markup # ခလုတ်ထည့်သွင်းခြင်း
        )

print("ခလုတ်များပါဝင်သော Userbot စတင် အလုပ်လုပ်နေပါပြီ...")
app.run()
