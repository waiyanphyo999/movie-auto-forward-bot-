from pyrogram import Client, filters
from pyrogram.types import InlineKeyboardMarkup, InlineKeyboardButton
import json
import os

# --- အချက်အလက်များ ---
API_ID = "YOUR_API_ID"
API_HASH = "YOUR_API_HASH"
BOT_TOKEN = "YOUR_BOT_TOKEN_HERE" # ခုနကရတဲ့ Token
ADMIN_ID = 123456789  # သင့်ရဲ့ Telegram ID (သင်တစ်ယောက်တည်းသာ ထိန်းချုပ်နိုင်ရန်)

app = Client("movie_bot", api_id=API_ID, api_hash=API_HASH, bot_token=BOT_TOKEN)

# Channel စာရင်းသိမ်းရန်
DB_FILE = "channels.json"

def load_channels():
    if not os.path.exists(DB_FILE): return []
    with open(DB_FILE, "r") as f: return json.load(f)

def save_channels(channels):
    with open(DB_FILE, "w") as f: json.dump(channels, f)

# --- ခလုတ်များ (Menu) ---
def get_main_keyboard():
    return InlineKeyboardMarkup([
        [InlineKeyboardButton("📋 ချန်နယ်စာရင်း", callback_data="list")],
        [InlineKeyboardButton("➕ ချန်နယ်ထည့်ရန်", callback_data="add"), InlineKeyboardButton("➖ ချန်နယ်ဖြုတ်ရန်", callback_data="del")]
    ])

@app.on_message(filters.command("start") & filters.user(ADMIN_ID))
async def start(client, message):
    await message.reply("🎬 Movie Auto Forward Bot သို့ ကြိုဆိုပါသည်။ အောက်ပါခလုတ်များဖြင့် အသုံးပြုနိုင်ပါသည်။ 👇", reply_markup=get_main_keyboard())

# --- Callback Handling (ခလုတ်နှိပ်လျှင်) ---
@app.on_callback_query()
async def callback(client, call):
    if call.data == "list":
        channels = load_channels()
        text = "📋 လက်ရှိ ချန်နယ်များ:\n" + "\n".join(channels) if channels else "ချန်နယ်မရှိသေးပါ။"
        await call.message.edit_text(text, reply_markup=get_main_keyboard())
    # (Add/Remove အတွက် ပိုမိုရှုပ်ထွေးတဲ့ FSM logic လိုအပ်ပါသည်၊ အလွယ်သုံးရန် command ဖြင့် အစားထိုးနိုင်သည်)

@app.on_message(filters.command("add") & filters.user(ADMIN_ID))
async def add_channel(client, message):
    chn = message.command[1]
    channels = load_channels()
    if chn not in channels:
        channels.append(chn)
        save_channels(channels)
        await message.reply(f"✅ {chn} ကို ထည့်သွင်းပြီးပါပြီ။")

# --- Movie ပို့စ်တင်ခြင်း (အဓိကအချက်) ---
@app.on_message(filters.media & filters.user(ADMIN_ID))
async def forward_movie(client, message):
    channels = load_channels()
    if not channels:
        await message.reply("❌ ချန်နယ်စာရင်း မရှိသေးပါ။")
        return
    
    for chn in channels:
        try:
            # Media (ပုံ/ဗီဒီယို) နှင့် စာသားကိုပါ ပို့ပေးမည်
            await message.copy(chn)
        except Exception as e:
            print(f"Error sending to {chn}: {e}")
    
    await message.reply(f"✅ ချန်နယ် {len(channels)} ခုသို့ တင်ပေးပြီးပါပြီ။")

app.run()
