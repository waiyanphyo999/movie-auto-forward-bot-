import asyncio
import json
import os
import requests
from pyrogram import Client, filters, compose
from pyrogram.types import InlineKeyboardMarkup, InlineKeyboardButton
import google.generativeai as genai

# --- ၁။ Render ၏ Environment Variables မှ အချက်အလက်များ ရယူခြင်း ---
# (Render တွင် ထည့်ထားသော Key အမည်များနှင့် တစ်ထပ်တည်း ဖြစ်ရပါမည်)
try:
    API_ID = int(os.getenv("API_ID"))
    ADMIN_ID = int(os.getenv("ADMIN_ID"))
except TypeError:
    print("❌ Error: API_ID သို့မဟုတ် ADMIN_ID ကို Render တွင် ထည့်ရန် ကျန်နေပါသည် (ဂဏန်းများသာ ဖြစ်ရမည်)")

API_HASH = os.getenv("API_HASH")
SESSION_STRING = os.getenv("SESSION_STRING")
BOT_TOKEN = os.getenv("BOT_TOKEN")
DESTINATION_CHANNEL = os.getenv("DESTINATION_CHANNEL")

GEMINI_API_KEY = os.getenv("GEMINI_API_KEY")
XAI_API_KEY = os.getenv("XAI_API_KEY")

# Gemini AI အသက်သွင်းခြင်း
if GEMINI_API_KEY:
    genai.configure(api_key=GEMINI_API_KEY)
    gemini_model = genai.GenerativeModel('gemini-pro')

# --- ၂။ Database (Channel စာရင်းသိမ်းရန်) ---
DB_FILE = "config.json"

def load_channels():
    if not os.path.exists(DB_FILE): return []
    with open(DB_FILE, "r") as f: return json.load(f)

def save_channels(channels):
    with open(DB_FILE, "w") as f: json.dump(channels, f)

# --- ၃။ Clients များ ဖန်တီးခြင်း ---
bot_app = Client("control_bot", api_id=API_ID, api_hash=API_HASH, bot_token=BOT_TOKEN)
user_app = Client("userbot", api_id=API_ID, api_hash=API_HASH, session_string=SESSION_STRING)

# --- AI ၂ ခုဖြင့် စာသားပြောင်းမည့် Function ---
def rewrite_text(original_text):
    prompt = f"အောက်ပါစာသားကို မြန်မာလိုပဲ အဓိပ္ပာယ်မပြောင်းဘဲ စာသား/အရေးအသား ပုံစံပြောင်းပြီး ပြန်ရေးပေးပါ။ ကြော်ငြာဆန်ဆန် ဆွဲဆောင်မှုရှိအောင် ရေးပေးပါ။:\n\n{original_text}"
    
    try:
        print("Gemini ဖြင့် စာသားပြောင်းနေပါသည်...")
        response = gemini_model.generate_content(prompt)
        return response.text
    except Exception as gemini_error:
        print(f"Gemini Error ဖြစ်သွားပါသည်: {gemini_error}")
        print("x.ai (Grok) ဖြင့် ပြောင်းလဲရန် ကြိုးစားနေပါသည်...")
        
        try:
            url = "https://api.x.ai/v1/chat/completions"
            headers = {
                "Content-Type": "application/json",
                "Authorization": f"Bearer {XAI_API_KEY}"
            }
            data = {
                "messages": [
                    {"role": "system", "content": "You are a helpful assistant that rewrites text attractively in Burmese language."},
                    {"role": "user", "content": prompt}
                ],
                "model": "grok-beta",
                "temperature": 0.7
            }
            xai_response = requests.post(url, headers=headers, json=data)
            xai_response.raise_for_status() 
            
            return xai_response.json()['choices'][0]['message']['content']
        except Exception as xai_error:
            print(f"x.ai လည်း Error ဖြစ်သွားပါသည်: {xai_error}")
            return original_text

# ==========================================
# BOT INTERFACE (ခလုတ်များဖြင့် ထိန်းချုပ်မည့်အပိုင်း)
# ==========================================

def main_menu():
    return InlineKeyboardMarkup([
        [InlineKeyboardButton("📋 စောင့်ကြည့်နေသော Channel များ", callback_data="list_channels")],
        [InlineKeyboardButton("➕ Channel အသစ်ထည့်ရန်", callback_data="add_channel")],
        [InlineKeyboardButton("➖ Channel ပြန်ဖျက်ရန်", callback_data="remove_channel")]
    ])

@bot_app.on_message(filters.command("start") & filters.user(ADMIN_ID))
async def start_cmd(client, message):
    await message.reply("🤖 **Dual AI Auto-Forward Bot** မှ ကြိုဆိုပါတယ်။\n\nအောက်ပါ ခလုတ်များကို အသုံးပြု၍ ထိန်းချုပ်နိုင်ပါသည်။ 👇", reply_markup=main_menu())

@bot_app.on_callback_query(filters.user(ADMIN_ID))
async def callback_handler(client, call):
    data = call.data
    if data == "list_channels":
        channels = load_channels()
        text = "📋 **လက်ရှိ စောင့်ကြည့်နေသော Channel များ:**\n\n" + ("\n".join(channels) if channels else "မည်သည့် Channel မှ မထည့်ရသေးပါ။")
        await call.message.edit_text(text, reply_markup=main_menu())
        
    elif data == "add_channel":
        await call.message.reply("➕ Channel အသစ်ထည့်ရန် အောက်ပါအတိုင်း ရိုက်ထည့်ပါ။\n\n` /add @channel_username `")
        
    elif data == "remove_channel":
        await call.message.reply("➖ Channel ပြန်ဖျက်ရန် အောက်ပါအတိုင်း ရိုက်ထည့်ပါ။\n\n` /del @channel_username `")

@bot_app.on_message(filters.command("add") & filters.user(ADMIN_ID))
async def add_cmd(client, message):
    if len(message.command) > 1:
        new_channel = message.command[1]
        channels = load_channels()
        if new_channel not in channels:
            channels.append(new_channel)
            save_channels(channels)
            await message.reply(f"✅ {new_channel} ကို အောင်မြင်စွာ ထည့်သွင်းပြီးပါပြီ။")
        else:
            await message.reply("⚠️ ဤ Channel မှာ စာရင်းထဲတွင် ရှိပြီးသားဖြစ်ပါသည်။")
    else:
        await message.reply("အသုံးပြုပုံ မှားယွင်းနေပါသည်။ ဥပမာ - `/add @channel_name`")

@bot_app.on_message(filters.command("del") & filters.user(ADMIN_ID))
async def del_cmd(client, message):
    if len(message.command) > 1:
        target = message.command[1]
        channels = load_channels()
        if target in channels:
            channels.remove(target)
            save_channels(channels)
            await message.reply(f"🗑️ {target} ကို စာရင်းမှ ဖျက်လိုက်ပါပြီ။")
    else:
        await message.reply("အသုံးပြုပုံ မှားယွင်းနေပါသည်။ ဥပမာ - `/del @channel_name`")

# ==========================================
# USERBOT CORE (စာဖတ်ခြင်း၊ AI ပြောင်းခြင်း၊ ပြန်တင်ခြင်း)
# ==========================================

@user_app.on_message(filters.channel)
async def auto_forward_and_rewrite(client, message):
    channels = load_channels()
    
    if message.chat.username:
        chat_username = f"@{message.chat.username}"
        if chat_username in channels:
            if message.text:
                new_text = rewrite_text(message.text)
                await client.send_message(DESTINATION_CHANNEL, new_text)
                
            elif message.photo or message.video:
                caption = message.caption if message.caption else ""
                new_caption = rewrite_text(caption) if caption else ""
                await message.copy(DESTINATION_CHANNEL, caption=new_caption)

# Script တစ်ခုတည်းတွင် Bot နှင့် Userbot နှစ်ခုလုံး တစ်ပြိုင်တည်း Run ရန်
async def main():
    print("Dual AI System is starting... Running both Bot and Userbot from Render Environment Variables.")
    await compose([bot_app, user_app])

if __name__ == "__main__":
    asyncio.run(main())
